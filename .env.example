# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/metaai

# Redis
REDIS_URL=redis://redis:6379/0

# Qdrant
QDRANT_URL=http://qdrant:6333

# Security
JWT_SECRET=change-this-to-a-random-secret-key
SECRET_KEY=change-this-to-another-random-key

# API Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# LangSmith
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=metaai

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=

# Environment
ENVIRONMENT=production
